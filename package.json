{
  "name": "linkstore",
  "version": "1.0.0",
  "description": "Multi-vendor store build with MERN and Next.js",
  "main": "backend/server.js",
  "scripts": {
    "dev:frontend": "cd frontend && npx next dev",
    "dev:backend": "npx nodemon backend/server.js",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "build": "cd frontend && npx next build",
    "start:frontend": "cd frontend && npx next start",
    "start:backend": "node backend/server.js",
    "lint": "cd frontend && npx next lint"
  },
  "dependencies": {
    "@reduxjs/toolkit": "^2.11.2",
    "axios": "^1.13.6",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.577.0",
    "mongoose": "^9.3.0",
    "multer": "^2.1.1",
    "next": "16.1.7",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-redux": "^9.2.0",
    "stripe": "^20.4.1",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "1.0.0",
    "concurrently": "^8.2.2",
    "eslint": "^9",
    "eslint-config-next": "16.1.7",
    "nodemon": "^3.1.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
